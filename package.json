  "author": "Karl Horky",
  "type": "module",
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "csv": "6.6.0",
    "table": "6.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.3",
    "eslint": "10.5.0",
    "eslint-config-upleveled": "10.0.0",
    "prettier": "3.8.4",
